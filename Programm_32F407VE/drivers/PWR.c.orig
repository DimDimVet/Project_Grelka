#include "PWR.h"

int countFillFactor=0;

void EXE_TASK4()
{
		    APB2_ENABLE_PERIPHERY(RCC_APB2ENR_SYSCFGEN);
    APB1_ENABLE_PERIPHERY(RCC_APB1ENR_TIM3EN);

    AHB1_ENABLE_PERIPHERY(RCC_AHB1ENR_GPIOAEN);/*выход PWR*/

		GPIO_Structure pwr_6 = {.GPIOx = GPIOA,.Pin = PIN6,.Mode = GPIO_MODE_AF,.Speed = GPIO_SPEED_LOW,.Alternate = GPIO_AF2};
	  GPIO_Init(&pwr_6);
}

void Init_Tim_PWR(int fillFactor)
{
    /*Устанавливаем предделитель и авто-перезагрузку*/
    Write_REG(TIM3->PSC,TIM_PRESCALE); /*делитель TIM prescaler*/
    Write_REG(TIM3->ARR,COUNT_RESET); /*автосброс*/
		
    /*ШИМ TIM3_CH1 PA6*/
    Write_REG(TIM3->CCR1,fillFactor); /*Коэффициент заполнения*/ 
    ENABLE_BIT(TIM3->CCMR1,TIM_MODE_PWR1); /*режим ШИМ TIM_CCMR1_OC1M_2 | TIM_CCMR1_OC1M_1*/

    ENABLE_BIT(TIM3->CCMR1, TIM_CCMR1_OC1PE);/*включен регистр предварительной загрузки*/
    ENABLE_BIT(TIM3->CCER, TIM_CCER_CC1E); /*включаем TIM3_CH1*/

    ENABLE_BIT(TIM3->CR1, TIM_CR1_CEN);/*Запуск таймера*/
}

