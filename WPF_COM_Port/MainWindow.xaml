<Window x:Class="WPF_COM_Port.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_COM_Port"
        mc:Ignorable="d"
        Title="Project Grelka" Height="450" Width="800">
    <Window.DataContext>
        <local:ViewModel/>
    </Window.DataContext>

    <Grid Margin="0,59,10,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="47*"/>
            <RowDefinition Height="328*"/>
        </Grid.RowDefinitions>
        <!--Stack1-->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Grid.Row="0">
            <ComboBox x:Name="PortCombo" ItemsSource="{Binding PortCombo}" SelectedItem="{Binding PortComboSelectItem}" SelectedIndex="{Binding PortComboSelectIndex}" Width="120" Margin="0,0,6,0"/>
            <ComboBox x:Name="BaudCombo" ItemsSource="{Binding BaudCombo}" SelectedItem="{Binding BaudComboSelectItem}" Width="100" Margin="0,0,6,0"/>
            <ComboBox x:Name="ParityCombo" ItemsSource="{Binding ParityCombo}" SelectedItem="{Binding ParityComboSelectItem}" Width="90" Margin="0,0,6,0"/>
            <ComboBox x:Name="DataBitsCombo" ItemsSource="{Binding DataBitsCombo}" SelectedItem="{Binding DataBitsComboSelectItem}" Width="70" Margin="0,0,6,0"/>
            <ComboBox x:Name="StopBitsCombo" ItemsSource="{Binding StopBitsCombo}" SelectedItem="{Binding StopBitsComboSelectItem}" Width="90" Margin="0,0,6,0"/>
            <CheckBox x:Name="RtsCheck" Content="RTS" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <CheckBox x:Name="DtrCheck" Content="DTR" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="HandshakeCombo" ItemsSource="{Binding HandshakeCombo}" SelectedItem="{Binding HandshakeComboSelectItem}" Width="130" Margin="0,0,6,0"/>
            <Button x:Name="RefreshBtn" Content="Refresh" Width="70" Command="{Binding RefreshBtnClick}" Margin="0,0,6,0"/>
            <Button x:Name="OpenBtn" Content="Open" Width="70" Command="{Binding OpenBtnClick}" Margin="0,0,6,0"/>
            <Button x:Name="CloseBtn" Content="Close" Width="70" Command="{Binding CloseBtnClick}" IsEnabled="False"/>
        </StackPanel>

        <TextBox x:Name="LogBox" Text="{Binding LogText}" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" Margin="31,10,25,98" Grid.Row="1"/>
        <!--Stack2-->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBox x:Name="SendBox" Text="{Binding SendBox}" Width="620" Height="28" VerticalContentAlignment="Center"/>
            <Button x:Name="SendBtn" Content="Send" Width="80" Command="{Binding SendBtnClick}" IsEnabled="False" Margin="6,0,6,0"/>
            <Button x:Name="ClearBtn" Content="Clear" Width="80" Command="{Binding ClearBtnClick}"/>
        </StackPanel>


    </Grid>
</Window>
